# ============================================================================
# Daemon8 app (TanStack Start) — environment configuration
# ============================================================================
#
# Two variables. Copy to .env and fill in values for your environment.

# Absolute URL of the Laravel API.
# Local dev: http://localhost:8977 (Laravel on a separate origin)
# Production: empty (Caddy proxies /api/* to the same origin)
LARAVEL_API_URL=http://localhost:8977

# Absolute URL of the marketing site itself.
# Local dev: http://localhost:3000
# Production: https://daemon8.ai
SITE_URL=http://localhost:3000
